-- ==========================================
-- 1. EXTENSIONS & CUSTOM TYPES
-- ==========================================
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- Define roles for your team
DO $$ BEGIN
    CREATE TYPE user_role AS ENUM ('admin', 'editor', 'viewer');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

-- Define workflow status for news
DO $$ BEGIN
    CREATE TYPE news_status AS ENUM ('draft', 'review', 'published', 'archived');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

-- ==========================================
-- 2. TABLES SETUP
-- ==========================================

-- User Profiles (Links to Supabase Auth)
CREATE TABLE IF NOT EXISTS profiles (
  id uuid REFERENCES auth.users ON DELETE CASCADE PRIMARY KEY,
  full_name text,
  username text UNIQUE,
  role user_role DEFAULT 'editor',
  avatar_url text,
  updated_at timestamp with time zone DEFAULT timezone('utc'::text, now())
);

-- News Items (The Core Content)
CREATE TABLE IF NOT EXISTS news_items (
  id uuid DEFAULT uuid_generate_v4() PRIMARY KEY,
  author_id uuid REFERENCES profiles(id) ON DELETE SET NULL,
  topic text NOT NULL,
  subtopic text,
  paragraphs jsonb DEFAULT '[]'::jsonb, 
  bullets jsonb DEFAULT '[]'::jsonb,
  images jsonb DEFAULT '[]'::jsonb,
  category text DEFAULT 'General',
  status news_status DEFAULT 'draft',
  is_active boolean DEFAULT false,
  created_at timestamp with time zone DEFAULT timezone('utc'::text, now()),
  updated_at timestamp with time zone DEFAULT timezone('utc'::text, now())
);

-- AI Generation Logs (Tracking AI Standards)
CREATE TABLE IF NOT EXISTS ai_logs (
  id uuid DEFAULT uuid_generate_v4() PRIMARY KEY,
  news_id uuid REFERENCES news_items(id) ON DELETE CASCADE,
  source_url text,
  prompt_used text,
  tokens_used int,
  model_name text DEFAULT 'gpt-4o',
  created_at timestamp with time zone DEFAULT timezone('utc'::text, now())
);

-- Social Media Account Connections
CREATE TABLE IF NOT EXISTS social_accounts (
  id uuid DEFAULT uuid_generate_v4() PRIMARY KEY,
  user_id uuid REFERENCES profiles(id) ON DELETE CASCADE,
  platform text NOT NULL, -- 'YouTube', 'TikTok', 'Telegram'
  account_handle text,
  api_key_encrypted text, 
  is_connected boolean DEFAULT true,
  last_used timestamp with time zone
);

-- Global System Configuration
CREATE TABLE IF NOT EXISTS system_config (
  id int PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
  config_key text UNIQUE NOT NULL,
  config_value text,
  description text
);

-- ==========================================
-- 3. INDEXES & CONSTRAINTS
-- ==========================================

-- Crucial: Ensures only ONE news item is "Live" globally at any time
CREATE UNIQUE INDEX IF NOT EXISTS idx_single_live_news 
ON news_items (is_active) 
WHERE (is_active = true);

-- Index for faster searching by status
CREATE INDEX IF NOT EXISTS idx_news_status ON news_items(status);

-- ==========================================
-- 4. AUTOMATION (Triggers for Updated_at)
-- ==========================================

CREATE OR REPLACE FUNCTION update_modified_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = now();
    RETURN NEW;
END;
$$ language 'plpgsql';

-- Apply triggers
DROP TRIGGER IF EXISTS update_news_modtime ON news_items;
CREATE TRIGGER update_news_modtime BEFORE UPDATE ON news_items 
FOR EACH ROW EXECUTE PROCEDURE update_modified_column();

DROP TRIGGER IF EXISTS update_profile_modtime ON profiles;
CREATE TRIGGER update_profile_modtime BEFORE UPDATE ON profiles 
FOR EACH ROW EXECUTE PROCEDURE update_modified_column();

